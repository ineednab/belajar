      font-family: var(--mono);
      font-size: 11px;
      color: var(--muted);
      min-width: 80px;
      letter-spacing: 0.04em;
    }

    .volunteer-desc {
      font-size: 0.95rem;
      line-height: 1.6;
    }

    /* ===========================
       FOOTER
    =========================== */
    footer {
      border-top: 1px solid var(--border);
      padding-top: 32px;
      margin-top: 60px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 12px;
    }

    footer p {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--muted);
      letter-spacing: 0.08em;
    }

    footer .footer-links {
      display: flex;
      gap: 20px;
    }

    footer .footer-links a {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--muted);
      text-decoration: none;
      letter-spacing: 0.06em;
      transition: color 0.2s;
    }

    footer .footer-links a:hover {
      color: var(--accent);
    }

    /* ===========================
       RESPONSIVE
    =========================== */
    @media (max-width: 640px) {
      .page-wrapper {
        padding: 40px 24px 80px;
      }

      .entry {
        grid-template-columns: 1fr;
        gap: 6px;
      }

      .partnerships-grid {
        grid-template-columns: 1fr;
      }

      footer {
        flex-direction: column;
        align-items: flex-start;
      }
    }
  </style>
</head>

