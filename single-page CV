  <style>
    /* ===========================
       CSS VARIABLES & RESET
    =========================== */
    :root {
      --cream: #F5F0E8;
      --ink: #1A1714;
      --muted: #7A746C;
      --accent: #C4572A;
      --accent-light: #E8C4B4;
      --border: #D8D0C4;
      --serif: 'Cormorant Garamond', Georgia, serif;
      --mono: 'DM Mono', 'Courier New', monospace;
    }

    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      background-color: var(--cream);
      color: var(--ink);
      font-family: var(--serif);
      font-size: 16px;
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }

    /* ===========================
       LAYOUT
    =========================== */
    .page-wrapper {
      max-width: 860px;
      margin: 0 auto;
      padding: 60px 40px 100px;
    }

    /* ===========================
       HEADER
    =========================== */
    header {
      border-bottom: 1px solid var(--border);
      padding-bottom: 40px;
      margin-bottom: 56px;
      position: relative;
    }

    .header-eyebrow {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 12px;
    }

    header h1 {
      font-family: var(--serif);
      font-size: clamp(2.8rem, 7vw, 5rem);
      font-weight: 300;
      letter-spacing: -0.02em;
      line-height: 1.05;
      margin-bottom: 20px;
    }

    header h1 em {
      font-style: italic;
      color: var(--accent);
    }

    .header-title {
      font-family: var(--mono);
      font-size: 13px;
      color: var(--muted);
      letter-spacing: 0.08em;
      margin-bottom: 24px;
    }

    .contact-line {
      display: flex;
      flex-wrap: wrap;
      gap: 6px 20px;
      font-family: var(--mono);
      font-size: 12px;
      color: var(--muted);
    }

    .contact-line a {
      color: var(--muted);
      text-decoration: none;
      border-bottom: 1px solid var(--border);
      transition: color 0.2s, border-color 0.2s;
    }

    .contact-line a:hover {
      color: var(--accent);
      border-color: var(--accent);
    }

    .contact-line span::before {
      content: "·";
      margin-right: 20px;
      color: var(--border);
    }

    .contact-line span:first-child::before {
      display: none;
    }

    /* ===========================
       SECTION LAYOUT
    =========================== */
    section {
      margin-bottom: 52px;
    }

    .section-header {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 28px;
    }

    .section-label {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--accent);
      white-space: nowrap;
    }

    .section-rule {
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    /* ===========================
       PROFILE / ABOUT
    =========================== */
    #about p {
      font-size: 1.2rem;
      font-weight: 300;
      line-height: 1.8;
      color: var(--ink);
      max-width: 680px;
    }

    #about p em {
      font-style: italic;
      color: var(--accent);
    }

    /* ===========================
       ENTRY (reusable for edu, work)
    =========================== */
    .entry {
      display: grid;
      grid-template-columns: 160px 1fr;
      gap: 0 32px;
      margin-bottom: 36px;
      padding-bottom: 36px;
      border-bottom: 1px solid var(--border);
    }

    .entry:last-child {
      border-bottom: none;
      margin-bottom: 0;
      padding-bottom: 0;
    }

    .entry-meta {
      padding-top: 3px;
    }

    .entry-date {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--muted);
      line-height: 1.5;
      letter-spacing: 0.05em;
    }

    .entry-org {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--accent);
      margin-top: 4px;
      letter-spacing: 0.04em;
    }

    .entry-content h3 {
      font-family: var(--serif);
      font-size: 1.3rem;
      font-weight: 400;
      line-height: 1.3;
      margin-bottom: 6px;
    }

    .entry-content h4 {
      font-family: var(--serif);
      font-size: 1rem;
      font-weight: 400;
      font-style: italic;
      color: var(--muted);
      margin-bottom: 10px;
    }

    .entry-content p {
      font-size: 0.95rem;
      color: var(--muted);
      line-height: 1.7;
      margin-bottom: 10px;
    }

    .entry-content ul {
      list-style: none;
      margin-top: 10px;
    }

    .entry-content ul li {
      font-size: 0.92rem;
      color: var(--ink);
      line-height: 1.7;
      padding-left: 16px;
      position: relative;
      margin-bottom: 4px;
    }

    .entry-content ul li::before {
      content: "—";
      position: absolute;
      left: 0;
      color: var(--accent);
      font-size: 0.8rem;
    }

    /* ===========================
       EDUCATION
    =========================== */
    #education .thesis {
      font-size: 0.88rem;
      font-style: italic;
      color: var(--muted);
      margin-top: 8px;
      line-height: 1.6;
    }

    /* ===========================
       SKILLS
    =========================== */
    .skills-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 24px;
    }

    .skill-group h3 {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 12px;
    }

    .skill-group ul {
      list-style: none;
    }

    .skill-group ul li {
      font-size: 0.95rem;
      line-height: 1.9;
      color: var(--ink);
      border-bottom: 1px solid var(--border);
      padding-bottom: 2px;
    }

    /* ===========================
       BRAND PARTNERSHIPS
    =========================== */
    .partnerships-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }

    .partnership-card {
      border: 1px solid var(--border);
      padding: 16px 18px;
    }

    .partnership-card h4 {
      font-family: var(--serif);
      font-size: 1rem;
      font-weight: 600;
      margin-bottom: 2px;
    }

    .partnership-card .period {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--accent);
      letter-spacing: 0.08em;
      margin-bottom: 6px;
    }

    .partnership-card p {
      font-size: 0.85rem;
      color: var(--muted);
      line-height: 1.6;
    }

    /* ===========================
       AWARDS
    =========================== */
    .award-row {
      display: flex;
      gap: 24px;
      padding: 14px 0;
      border-bottom: 1px solid var(--border);
      align-items: baseline;
    }

    .award-row:last-child {
      border-bottom: none;
    }

    .award-year {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--accent);
      min-width: 60px;
      letter-spacing: 0.05em;
    }

    .award-desc {
      font-size: 0.95rem;
      line-height: 1.6;
    }

    /* ===========================
       VOLUNTEER
    =========================== */
    .volunteer-row {
      display: flex;
      gap: 24px;
      padding: 12px 0;
      border-bottom: 1px solid var(--border);
      align-items: baseline;
    }

    .volunteer-row:last-child {
